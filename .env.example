# Environment variables for development (copy to .env and customize)
# DO NOT commit .env to version control

# Database Configuration
POSTGRES_DB=ecommerce_db
POSTGRES_USER=ecommerce_user
POSTGRES_PASSWORD=your_secure_db_password_here_change_me

# Application Secrets
JWT_SECRET=your_jwt_secret_key_minimum_256_bits_change_me
JWT_EXPIRATION=86400000

# Upload Configuration
UPLOAD_DIR=/app/uploads

# Redis Configuration (if using)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_change_me

# Spring Configuration
SPRING_PROFILES_ACTIVE=docker

# Logging Level
LOGGING_LEVEL_COM_HAND_DEMO=INFO
LOGGING_LEVEL_SQL=WARN

# Server Configuration
SERVER_PORT=8080